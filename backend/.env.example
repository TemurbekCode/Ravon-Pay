# Bu faylni "backend/.env" nomi bilan nusxalab, haqiqiy qiymatlarni kiriting.
# ".env" fayli hech qachon Git'ga qo'shilmaydi (.gitignore'da) — faqat shu
# ".env.example" andozasi commit qilinadi.

# JWT tokenlarini imzolash uchun maxfiy kalit. Tasodifiy uzun qatordan foydalaning, masalan:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Kiritilmasa, server har ishga tushganda vaqtinchalik tasodifiy kalit yaratadi
# (bu holatda qayta ishga tushirilganda barcha sessiyalar bekor bo'ladi).
JWT_SECRET=

# Server porti (ixtiyoriy, standart 4000)
PORT=4000

# Frontend qaysi manzildan so'rov yuborishiga ruxsat berilsin (CORS). Bir nechta
# manzil bo'lsa vergul bilan ajrating, masalan: http://localhost:5173,https://ravonpay.uz
CORS_ORIGIN=http://localhost:5173

# Google orqali kirish uchun ixtiyoriy — Google Cloud Console'da yaratilgan OAuth
# Client ID. Backend bu qiymatni shart qilib talab qilmaydi (frontend'dagi
# VITE_GOOGLE_CLIENT_ID ishlatiladi), lekin kelajakda serverda ham tekshirish
# kerak bo'lsa shu yerga qo'shiladi.
# GOOGLE_CLIENT_ID=

# ============================================================
# TO'LOV PROVAYDERI — hozircha sozlanmasa "mock" ishlaydi (pul darhol
# hamyonga tushadi, demo/dev xatti-harakati). Real Payme yoki Click
# kalitlaringiz bo'lganda quyidagilarni to'ldirib PAYMENT_PROVIDER'ni
# almashtiring — kodni o'zgartirish shart emas.
# ============================================================
# PAYMENT_PROVIDER=mock   # mock | payme | click

# --- Payme Business (developer.help.paycom.uz) ---
# PAYME_MERCHANT_ID=
# PAYME_KEY=

# --- Click Merchant (docs.click.uz) ---
# CLICK_SERVICE_ID=
# CLICK_MERCHANT_ID=
# CLICK_SECRET_KEY=

# --- Payoneer White-label Partner API (faqat hamkorlik tasdiqlangach) ---
# Xalqaro frilanser/dropshipping daromadini chiqarish uchun, hamyon to'ldirish
# uchun EMAS — alohida oqim, PAYMENT_PROVIDER orqali tanlanmaydi.
# PAYONEER_CLIENT_ID=
# PAYONEER_CLIENT_SECRET=
# PAYONEER_PROGRAM_ID=
