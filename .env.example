# Bu faylni "RavonPay/.env" nomi bilan nusxalab, kerakli qiymatlarni kiriting.
# ".env" fayli Git'ga qo'shilmaydi (.gitignore'da) — faqat shu andoza commit qilinadi.
# Vite'da faqat "VITE_" bilan boshlangan o'zgaruvchilar brauzerga chiqariladi —
# shuning uchun bu yerga hech qachon maxfiy (server-only) kalit qo'ymang.

# Backend manzili. Bo'sh qoldirilsa standart http://localhost:4000/api/v1 ishlatiladi.
VITE_API_URL=http://localhost:4000/api/v1

# Google orqali kirish tugmasi ishlashi uchun — Google Cloud Console'da yaratilgan
# OAuth 2.0 Client ID (bu qiymat OMMAVIY, maxfiy emas — frontend kodida ko'rinishi normal).
# Olish uchun: https://console.cloud.google.com/apis/credentials
#   1. "Create Credentials" -> "OAuth client ID" -> "Web application"
#   2. "Authorized JavaScript origins" ga: http://localhost:5173 (va production domeningizni) qo'shing
#   3. Yaratilgan Client ID'ni shu yerga qo'ying
# Bo'sh qoldirilsa, Google tugmasi bosilganda tushunarli xabar chiqadi (ilova buzilmaydi).
VITE_GOOGLE_CLIENT_ID=
